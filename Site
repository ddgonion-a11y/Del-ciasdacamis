<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delícias da Camis - Sucos Naturais</title>
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Poppins:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #fff8e1 0%, #ffecb3 50%, #ffe082 100%);
            overflow-x: hidden;
        }

        /* Animação flutuante */
        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-15px); }
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        @keyframes shimmer {
            0% { background-position: -200% center; }
            100% { background-position: 200% center; }
        }

        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        /* Header */
        .header {
            background: linear-gradient(135deg, #ff9800 0%, #f57c00 50%, #e65100 100%);
            padding: 40px 20px;
            text-align: center;
            position: relative;
            overflow: hidden;
            box-shadow: 0 10px 40px rgba(230, 81, 0, 0.3);
        }

        .header::before {
            content: '🍊 🍋 🍓 🥭 🍍';
            position: absolute;
            font-size: 30px;
            top: 10px;
            left: -50px;
            animation: float 6s ease-in-out infinite;
            opacity: 0.3;
        }

        .header::after {
            content: '🍇 🥝 🍑 🍒 🥥';
            position: absolute;
            font-size: 30px;
            bottom: 10px;
            right: -50px;
            animation: float 6s ease-in-out infinite reverse;
            opacity: 0.3;
        }

        .logo {
            font-family: 'Pacifico', cursive;
            font-size: 3.5rem;
            color: #fff;
            text-shadow: 3px 3px 6px rgba(0,0,0,0.3);
            animation: float 3s ease-in-out infinite;
            position: relative;
            z-index: 1;
        }

        .tagline {
            color: #fffde7;
            font-size: 1.2rem;
            margin-top: 10px;
            font-weight: 300;
            letter-spacing: 2px;
        }

        /* Hero Section */
        .hero {
            text-align: center;
            padding: 50px 20px;
            background: url('https://images.unsplash.com/photo-1623065422902-30a2d299bbe4?w=1200') center/cover;
            position: relative;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(255, 152, 0, 0.85);
        }

        .hero-content {
            position: relative;
            z-index: 1;
        }

        .hero h2 {
            font-size: 2.5rem;
            color: #fff;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
            margin-bottom: 20px;
        }

        .hero p {
            color: #fff8e1;
            font-size: 1.1rem;
            max-width: 600px;
            margin: 0 auto;
        }

        /* Sucos Section */
        .sucos-section {
            padding: 60px 20px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .section-title {
            text-align: center;
            font-size: 2.5rem;
            color: #e65100;
            margin-bottom: 10px;
            font-weight: 800;
        }

        .section-subtitle {
            text-align: center;
            color: #f57c00;
            font-size: 1.1rem;
            margin-bottom: 50px;
        }

        .sucos-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            margin-bottom: 40px;
        }

        .suco-card {
            background: #fff;
            border-radius: 25px;
            padding: 30px;
            text-align: center;
            box-shadow: 0 15px 35px rgba(230, 81, 0, 0.15);
            transition: all 0.4s ease;
            position: relative;
            overflow: hidden;
            border: 3px solid transparent;
        }

        .suco-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 5px;
            background: var(--card-color);
        }

        .suco-card:hover {
            transform: translateY(-10px) scale(1.02);
            box-shadow: 0 25px 50px rgba(230, 81, 0, 0.25);
            border-color: var(--card-color);
        }

        .suco-emoji {
            font-size: 4rem;
            margin-bottom: 15px;
            animation: bounce 2s ease-in-out infinite;
            display: block;
        }

        .suco-card:nth-child(2) .suco-emoji { animation-delay: 0.2s; }
        .suco-card:nth-child(3) .suco-emoji { animation-delay: 0.4s; }
        .suco-card:nth-child(4) .suco-emoji { animation-delay: 0.6s; }
        .suco-card:nth-child(5) .suco-emoji { animation-delay: 0.8s; }
        .suco-card:nth-child(6) .suco-emoji { animation-delay: 1s; }

        .suco-nome {
            font-size: 1.5rem;
            font-weight: 700;
            color: #333;
            margin-bottom: 8px;
        }

        .suco-desc {
            color: #666;
            font-size: 0.95rem;
            line-height: 1.5;
        }

        .suco-tag {
            display: inline-block;
            background: var(--card-color);
            color: #fff;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
            margin-top: 15px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* Açaí Section */
        .acai-section {
            background: linear-gradient(135deg, #4a148c 0%, #6a1b9a 50%, #8e24aa 100%);
            padding: 60px 20px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .acai-section::before {
            content: '🫐 🍇 🍫';
            position: absolute;
            font-size: 40px;
            top: 20px;
            right: 20px;
            animation: float 4s ease-in-out infinite;
            opacity: 0.2;
        }

        .acai-card {
            background: rgba(255,255,255,0.95);
            max-width: 500px;
            margin: 0 auto;
            border-radius: 30px;
            padding: 40px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            position: relative;
            z-index: 1;
        }

        .acai-card .suco-emoji {
            font-size: 5rem;
        }

        .acai-card .suco-nome {
            font-size: 2rem;
            color: #4a148c;
        }

        /* WhatsApp Button */
        .whatsapp-section {
            padding: 60px 20px;
            text-align: center;
            background: linear-gradient(180deg, #fff8e1 0%, #fff 100%);
        }

        .whatsapp-btn {
            display: inline-flex;
            align-items: center;
            gap: 15px;
            background: linear-gradient(135deg, #25d366 0%, #128c7e 100%);
            color: #fff;
            text-decoration: none;
            padding: 25px 60px;
            border-radius: 60px;
            font-size: 1.4rem;
            font-weight: 700;
            box-shadow: 0 15px 40px rgba(37, 211, 102, 0.4);
            transition: all 0.3s ease;
            animation: pulse 2s ease-in-out infinite;
            border: 4px solid #fff;
        }

        .whatsapp-btn:hover {
            transform: scale(1.08);
            box-shadow: 0 20px 60px rgba(37, 211, 102, 0.6);
        }

        .whatsapp-btn svg {
            width: 35px;
            height: 35px;
            fill: #fff;
        }

        .btn-text {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
        }

        .btn-text small {
            font-size: 0.8rem;
            font-weight: 400;
            opacity: 0.9;
        }

        .whatsapp-section p {
            color: #666;
            margin-top: 20px;
            font-size: 1rem;
        }

        /* Footer */
        .footer {
            background: #e65100;
            color: #fff;
            text-align: center;
            padding: 30px 20px;
            font-size: 0.9rem;
        }

        .footer .logo-small {
            font-family: 'Pacifico', cursive;
            font-size: 1.5rem;
            margin-bottom: 10px;
        }

        /* Floating WhatsApp */
        .float-whatsapp {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: #25d366;
            color: #fff;
            width: 65px;
            height: 65px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 30px rgba(37, 211, 102, 0.5);
            z-index: 1000;
            animation: pulse 2s ease-in-out infinite;
            transition: all 0.3s ease;
            text-decoration: none;
        }

        .float-whatsapp:hover {
            transform: scale(1.1);
        }

        .float-whatsapp svg {
            width: 35px;
            height: 35px;
            fill: #fff;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .logo { font-size: 2.5rem; }
            .section-title { font-size: 1.8rem; }
            .sucos-grid { grid-template-columns: 1fr; }
            .whatsapp-btn { padding: 20px 40px; font-size: 1.1rem; }
        }

        /* Sparkle effect */
        .sparkle {
            position: absolute;
            color: #ffd700;
            font-size: 20px;
            animation: float 3s ease-in-out infinite;
            pointer-events: none;
        }
    </style>
</head>
